---
import Default from '@astrojs/starlight/components/SiteTitle.astro';

const base = import.meta.env.BASE_URL;
const segments = base.split('/').filter(Boolean);
const currentVersion = segments[segments.length - 1] || 'edge';
const versionSuffix = `${currentVersion}/`;
const versionsRoot = base.endsWith(versionSuffix)
  ? base.slice(0, -versionSuffix.length)
  : base;
const versionsJsonUrl = `${versionsRoot}versions.json`;
---

<div class="site-title-with-versions">
  <Default><slot /></Default>

  <div class="version-switcher" data-current={currentVersion} data-versions-url={versionsJsonUrl}>
    <label class="sr-only" for="docs-version-switcher">Select documentation version</label>
    <select id="docs-version-switcher" aria-label="Select documentation version">
      <option value={currentVersion} selected>{currentVersion}</option>
    </select>
  </div>
</div>

<style>
  .site-title-with-versions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }

  .version-switcher select {
    appearance: auto;
    font-size: var(--sl-text-xs);
    line-height: 1.2;
    padding: 0.15rem 0.3rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-gray-5);
    background-color: var(--sl-color-black);
    color: var(--sl-color-white);
    cursor: pointer;
    max-width: 9rem;
  }

  .version-switcher select:hover {
    border-color: var(--sl-color-gray-4);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  (() => {
    const root = document.querySelector<HTMLElement>('.version-switcher');
    if (!root) return;
    const select = root.querySelector<HTMLSelectElement>('select');
    if (!select) return;

    const current = root.dataset.current || 'edge';
    const versionsUrl = root.dataset.versionsUrl;
    const base = import.meta.env.BASE_URL;
    const suffix = `${current}/`;
    const versionsRoot = base.endsWith(suffix) ? base.slice(0, -suffix.length) : base;

    function relativePagePath(): string {
      let path = window.location.pathname;
      if (path.startsWith(base)) path = path.slice(base.length);
      return path.replace(/^\//, '');
    }

    async function hydrate() {
      if (!versionsUrl) return;
      let data: { default?: string; versions?: Array<{ slug: string; label?: string }> };
      try {
        const res = await fetch(versionsUrl, { headers: { Accept: 'application/json' } });
        if (!res.ok) return;
        data = await res.json();
      } catch {
        return;
      }
      const versions = Array.isArray(data.versions) ? data.versions : [];
      if (versions.length === 0) return;

      select.innerHTML = '';
      let matchedCurrent = false;
      for (const v of versions) {
        if (!v || typeof v.slug !== 'string') continue;
        const opt = document.createElement('option');
        opt.value = v.slug;
        opt.textContent = v.label || v.slug;
        if (v.slug === current) {
          opt.selected = true;
          matchedCurrent = true;
        }
        select.appendChild(opt);
      }
      if (!matchedCurrent) {
        const opt = document.createElement('option');
        opt.value = current;
        opt.textContent = current;
        opt.selected = true;
        select.insertBefore(opt, select.firstChild);
      }
    }

    select.addEventListener('change', async () => {
      const target = select.value;
      if (!target || target === current) return;
      const page = relativePagePath();
      const targetBase = `${versionsRoot}${target}/`;
      const candidate = `${targetBase}${page}`;

      let dest = candidate;
      try {
        const head = await fetch(candidate, { method: 'HEAD' });
        if (!head.ok) dest = targetBase;
      } catch {
        dest = targetBase;
      }
      window.location.assign(dest);
    });

    hydrate();
  })();
</script>
